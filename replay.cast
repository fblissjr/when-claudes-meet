[0.000, "o", "  \u001b[38;5;51m│\u001b[0m     \u001b[38;5;33msend\u001b[0m \u001b[38;5;196m\"data\"\u001b[0m, 42                                                        \u001b[38;5;51m│\u001b[0m\r\n  \u001b[38;5;51m│\u001b[0m }, {                                                                       \u001b[38;5;51m│\u001b[0m\r\n  \u001b[38;5;51m│\u001b[0m     \u001b[38;5;33mlet\u001b[0m v = \u001b[38;5;33mreceive\u001b[0m \u001b[38;5;196m\"data\"\u001b[0m                                                 \u001b[38;5;51m│\u001b[0m\r\n  \u001b[38;5;51m│\u001b[0m     \u001b[38;5;33mprint\u001b[0m v  \u001b[38;5;40m// 42\u001b[0m                                                         \u001b[38;5;51m│\u001b[0m\r\n  \u001b[38;5;51m│\u001b[0m }                                                                          \u001b[38;5;51m│\u001b[0m\r\n  \u001b[38;5;51m╰────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[0.551, "o", "\r\n  \u001b[38;5;33m\u001b[1mHow Agents Worked                  \u001b[0m  \u001b[38;5;196m\u001b[1mHow Duo Programs Work\u001b[0m\r\n  \u001b[38;5;245m───────────────────────────────────  ───────────────────────────────────\u001b[0m\r\n  \u001b[38;5;255mTwo Claude processes               \u001b[0m  \u001b[38;5;51mTwo collaborate blocks\u001b[0m\r\n"]
[0.115, "o", "  \u001b[38;5;255mFiles as messages                  \u001b[0m  \u001b[38;5;51mChannels as messages\u001b[0m\r\n"]
[0.115, "o", "  \u001b[38;5;255mWriting a file = send              \u001b[0m  \u001b[38;5;51msend \"channel\", value\u001b[0m\r\n"]
[0.115, "o", "  \u001b[38;5;255mReading a file = receive           \u001b[0m  \u001b[38;5;51mlet v = receive \"channel\"\u001b[0m\r\n"]
[0.115, "o", "  \u001b[38;5;255mShared workspace directory         \u001b[0m  \u001b[38;5;51mShared channel store\u001b[0m\r\n"]
[0.395, "o", "\r\n"]
[0.000, "o", "                      \u001b[3m\u001b[38;5;200mThe language is about collaboration\u001b[0m\r\n                    \u001b[3m\u001b[38;5;200mbecause it was born from collaboration.\u001b[0m\r\n"]
[1.105, "o", "\u001b[2J\u001b[H\r\n"]
[0.000, "o", "\u001b[38;5;196m════════════════════════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[0.000, "o", "                    \u001b[1m\u001b[38;5;196mEXPERIMENT 2: THE BATTLESHIP TOURNAMENT\u001b[0m\r\n\u001b[38;5;196m════════════════════════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[0.555, "o", "\r\n"]
