[0.335, "o", "  \u001b[38;5;255m     2\u001b[0m  \u001b[38;5;245m74259       \u001b[0m  \u001b[38;5;196m\u001b[1m74259\u001b[0m  \u001b[38;5;255m  111\u001b[0m  \u001b[38;5;245mSlow grind. 74259 leads 2-0\u001b[0m\r\n"]
