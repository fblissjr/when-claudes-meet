[0.000, "o", "  \u001b[38;5;220m│\u001b[0m \u001b[38;5;33m\u001b[1mThe Hunter (74071)\u001b[0m: avg 71.3 moves/win -- exact computation                \u001b[38;5;220m│\u001b[0m\r\n  \u001b[38;5;220m│\u001b[0m \u001b[38;5;196m\u001b[1mThe Bayesian (74259)\u001b[0m: avg 100.5 moves/win -- Monte Carlo sampling          \u001b[38;5;220m│\u001b[0m\r\n"]
