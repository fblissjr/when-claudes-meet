// Closures in Duo — functions that capture their environment

fn make_counter(start) {
    let count = start
    return fn() {
        count = count + 1
        return count
    }
}

let counter = make_counter(0)
print counter()  // 1
print counter()  // 2
print counter()  // 3

// Another closure example: function factory
fn make_adder(n) {
    return fn(x) { return x + n }
}

let add5 = make_adder(5)
let add10 = make_adder(10)
print add5(3)    // 8
print add10(3)   // 13
